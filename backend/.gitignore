ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Only uncomment if you're sure you want to ignore it.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or experience
#   issues with locking, uncomment the next line:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies and should be vced.
#   Uncomment if you want to ignore poetry.lock:
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the resolved dependencies and should be vced.
#   Uncomment if you want to ignore pdm.lock:
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/

